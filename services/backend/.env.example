PORT=4000
DATABASE_FILE=./data/softupakaran.db

# Legacy (simple) admin token - optional but supported for admin endpoints
ADMIN_TOKEN=CHANGE_ME_ADMIN_TOKEN

# JWT auth (recommended)
JWT_SECRET=CHANGE_ME_STRONG_SECRET
JWT_EXPIRES_IN=7d
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_SECRET=CHANGE_ME_REFRESH_SECRET
ACCESS_TOKEN_COOKIE_NAME=spk_access
REFRESH_TOKEN_COOKIE_NAME=spk_refresh
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
AUTH_RATE_LIMIT_WINDOW=1m
AUTH_RATE_LIMIT_LOGIN_MAX=20
AUTH_RATE_LIMIT_REGISTER_MAX=8
AUTH_RATE_LIMIT_GOOGLE_MAX=20
AUTH_RATE_LIMIT_REFRESH_MAX=40
AUTH_LOCKOUT_THRESHOLD=6
AUTH_LOCKOUT_WINDOW=15m
AUTH_LOCKOUT_DURATION=30m

# Admin user (created automatically on first run if not existing)
ADMIN_EMAIL=admin@softupakaran.local
ADMIN_PASSWORD=admin12345

# CORS allowlist for frontend origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8085
FRONTEND_URL=http://localhost:8085

# Google Identity Services (for Gmail login)
GOOGLE_CLIENT_ID=161160759250-tvcu3a09i8gtdeaia6gpk04jo343oiet.apps.googleusercontent.com
GOOGLE_CLIENT_IDS=161160759250-tvcu3a09i8gtdeaia6gpk04jo343oiet.apps.googleusercontent.com
